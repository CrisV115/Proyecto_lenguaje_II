{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: runserver (.venv)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "program": "${workspaceFolder}\\manage.py",
      "args": [
        "runserver"
      ],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal",
      "env": {
        "VIRTUAL_ENV": "${workspaceFolder}\\.venv",
        "PATH": "${workspaceFolder}\\.venv\\Scripts;${env:PATH}"
      }
    },
    {
      "name": "Django: tests (.venv)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "program": "${workspaceFolder}\\manage.py",
      "args": [
        "test"
      ],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal",
      "env": {
        "VIRTUAL_ENV": "${workspaceFolder}\\.venv",
        "PATH": "${workspaceFolder}\\.venv\\Scripts;${env:PATH}"
      }
    }
  ]
}
